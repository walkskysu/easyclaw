{
  "name": "llm-chat-electron",
  "version": "1.0.0",
  "description": "A Windows Electron app for chatting with LLMs",
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node src/server/server.js",
    "electron": "electron .",
    "electron-dev": "set ELECTRON_RENDERER_URL=http://127.0.0.1:5173&& concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && electron .\"",
    "electron-build": "vite build && electron-builder"
  },
  "dependencies": {
    "@wechatbot/wechatbot": "^2.1.1",
    "axios": "^1.5.0",
    "body-parser": "^1.20.2",
    "dompurify": "^3.0.6",
    "express": "^4.18.2",
    "marked": "^11.1.1",
    "vue": "^3.3.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.2",
    "@types/node": "^20.8.0",
    "@vitejs/plugin-vue": "^4.4.0",
    "concurrently": "^9.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
    "vue-tsc": "^1.8.13",
    "wait-on": "^8.0.1"
  }
}
